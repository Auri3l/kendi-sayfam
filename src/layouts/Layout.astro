---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	activePage?: string;
}

const { 
	title = "Ata Yiğit Telli | İnşaat Mühendisi & Proje Yöneticisi", 
	description = "Ata Yiğit Telli - İnşaat Mühendisi. Büyük ölçekli projelerde saha şefliği, proje yönetimi ve sözleşme uzmanlığı.",
	activePage = "home" 
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title}</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="dark-theme">
    <!-- Custom Cursor Effect -->
    <div class="custom-cursor"></div>
    <div class="custom-cursor-dot"></div>

    <!-- Navigation Header -->
    <header class="main-header">
        <div class="header-container">
            <a href={base} class="logo-monogram" aria-label="Ana Sayfa">
                <span>AYT</span>
            </a>
            
            <nav class="nav-menu" id="navMenu">
                <ul>
                    <li><a href={`${base}#hakkimda`} class={`nav-link ${activePage === 'home' ? 'active' : ''}`}>Hakkımda (CV)</a></li>
                    <li><a href={`${base}#projeler`} class={`nav-link ${activePage === 'home' ? 'active' : ''}`}>Projeler</a></li>
                    <li><a href={`${base}simulasyon/`} class={`nav-link ${activePage === 'simulasyon' ? 'active' : ''}`}>Simülatör</a></li>
                    <li><a href={`${base}blog/`} class={`nav-link ${activePage === 'blog' ? 'active' : ''}`}>Blog</a></li>
                    <li><a href={`${base}iletisim/`} class={`nav-link ${activePage === 'iletisim' ? 'active' : ''}`}>İletişim</a></li>
                </ul>
            </nav>

            <div class="header-actions">
                <!-- Theme Switcher Button -->
                <button id="themeToggle" class="theme-toggle-btn" aria-label="Temayı Değiştir" title="Endüstriyel Açık / Endüstriyel Koyu Temalar Arasında Geçiş Yap">
                    <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20">
                        <circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
                        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    </svg>
                </button>
                
                <!-- Mobile Navigation Toggle -->
                <button id="mobileNavToggle" class="mobile-nav-toggle" aria-label="Menüyü Aç/Kapat">
                    <span class="bar"></span>
                    <span class="bar"></span>
                    <span class="bar"></span>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content Slot -->
    <slot />

    <!-- Footer -->
    <footer class="main-footer">
        <div class="container footer-container">
            <p class="copyright">© 2026 Ata Yiğit Telli. Tüm hakları saklıdır.</p>
        </div>
    </footer>

    <!-- Custom Toast Notification Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Centralized Script -->
    <script src="../scripts/main.js"></script>
</body>
</html>
