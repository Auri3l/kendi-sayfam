---
import Layout from '../layouts/Layout.astro';
import { PROFILE_DATA } from '../data/profileData';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout activePage="home">
    <main>
        <!-- Hero Section -->
        <section id="hero" class="hero-section">
            <div class="hero-bg-grid"></div>
            <div class="container hero-container">
                <div class="hero-content">
                    <span class="hero-badge">PORTFOLYO &amp; CV</span>
                    <h1 class="hero-title">Ata Yiğit Telli</h1>
                    <h2 class="hero-subtitle">İnşaat Mühendisi &amp; Proje Yöneticisi</h2>
                    <p class="hero-lead">
                        Büyük ölçekli üst yapı projelerinde, ana müteahhitlere hizmet veren lider taşeron firmalarda 8 yıl boyunca saha, şantiye yönetimi ve teknik sözleşme süreçlerinde kilit sorumluluklar üstlendim.
                    </p>
                    
                    <!-- Quick Contact Buttons -->
                    <div class="hero-cta-group">
                        <a href={`${base}iletisim/`} class="btn btn-primary">İletişime Geç</a>
                        <a href="https://www.linkedin.com/in/ay-t" target="_blank" rel="noopener" class="btn btn-secondary btn-icon" id="linkedinLink">
                            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                            </svg>
                            LinkedIn Profilim
                        </a>
                    </div>
                </div>

                <!-- Hero Meta Card -->
                <div class="hero-meta-card">
                    <div class="meta-card-inner">
                        <div class="meta-item">
                            <span class="meta-label">Telefon</span>
                            <a href="tel:+905321567693" class="meta-value">0532 156 76 93</a>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">E-posta</span>
                            <a href="mailto:ytelli@gmail.com" class="meta-value">ytelli@gmail.com</a>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Konum</span>
                            <span class="meta-value">Tuzla / İstanbul</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="scroll-indicator">
                <span class="mouse-icon"><span class="wheel"></span></span>
                <span class="scroll-text">Aşağı Kaydır</span>
            </div>
        </section>

        <!-- Hakkımda (CV) Ana Section -->
        <section id="hakkimda" class="section section-padding">
            <div class="container">
                <div class="section-header">
                    <span class="section-tag">Kişisel &amp; Profesyonel</span>
                    <h3 class="section-title">Hakkımda (CV)</h3>
                    <div class="section-divider"></div>
                </div>

                <!-- Kariyer Özeti -->
                <div class="summary-grid">
                    <div class="summary-text-block">
                        <p>
                            Okan Üniversitesi'nde İngilizce İnşaat Mühendisliği lisans ve İstanbul Gedik Üniversitesi'nde İş Sağlığı ve Güvenliği alanında yüksek lisans derecelerim bulunmaktadır. Şantiye operasyonları, proje koordinasyonu ve taşeron sözleşme yönetimi alanında geniş bir tecrübeye sahibim.
                        </p>
                        <p>
                            Üstlendiğim saha sorumluluğu ve proje şefliği rollerinde; ana müteahhitlerin kalite, kapsam ve takvim hedefleriyle tam uyumlu şantiye yönetimi, taşeron ekiplerin sevk ve idaresi ile teknik şartnamelere ve sözleşmelere uygunluk süreçlerini başarıyla yürüttüm.
                        </p>
                    </div>

                    <!-- Counter Stats -->
                    <div class="stats-container">
                        <!-- Toplam Deneyim (Geniş Kart) -->
                        <div class="stat-card full-width">
                            <span class="stat-number" id="statTotalYrs">10+</span>
                            <span class="stat-label">Yıl Proje &amp; Saha Deneyimi</span>
                        </div>
                        <!-- Cephe Uzmanlığı -->
                        <div class="stat-card">
                            <span class="stat-number" id="statFacadeYrs">8 Yıl</span>
                            <span class="stat-label">Cephe Mühendisliği Uzmanlığı</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-number" id="statProjects">6+</span>
                            <span class="stat-label">Büyük Proje Tecrübesi</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-number" id="statAcademic">2</span>
                            <span class="stat-label">Akademik Derece</span>
                        </div>
                        <div class="stat-card">
                            <span class="stat-number" id="statLanguages">6</span>
                            <span class="stat-label">Konuşulan Dil</span>
                        </div>
                    </div>
                </div>

                <!-- Mesleki Deneyim (Alt Başlık) -->
                <div class="cv-sub-section">
                    <h4 class="sub-section-title">Mesleki Deneyim</h4>
                    
                    <!-- Interactive Filters for Timeline -->
                    <div class="timeline-filters">
                        <button class="filter-btn active" data-filter="all">Tüm Deneyim</button>
                        <button class="filter-btn" data-filter="cephe">Cephe İşleri</button>
                        <button class="filter-btn" data-filter="yonetim">Sözleşme &amp; Yönetim</button>
                        <button class="filter-btn" data-filter="saha">Saha &amp; Uygulama</button>
                    </div>

                    <!-- Dynamic Timeline Container -->
                    <div class="timeline-container" id="timelineContainer">
                        {PROFILE_DATA.experiences.map((exp, idx) => {
                            const categoriesStr = exp.categories.join(' ');
                            return (
                                <div class="timeline-item reveal" data-categories={categoriesStr} style={`animation-delay: ${idx * 0.1}s`}>
                                    <div class="timeline-node"></div>
                                    <div class="timeline-meta">
                                        <span class="timeline-date">{exp.period}</span>
                                        <span class="timeline-location">{exp.location}</span>
                                    </div>
                                    <div class="timeline-card">
                                        <h4 class="timeline-role-title">{exp.role}</h4>
                                        <h5 class="timeline-company">{exp.company}</h5>
                                        <p class="timeline-desc">{exp.description}</p>
                                        
                                        {exp.details && (
                                            <ul class="timeline-details">
                                                {exp.details.map(det => <li>{det}</li>)}
                                            </ul>
                                        )}

                                        {exp.subRoles && (
                                            <div class="timeline-sub-roles">
                                                <span class="sub-role-title">Kariyer Basamakları</span>
                                                <div class="sub-roles-grid">
                                                    {exp.subRoles.map(sub => (
                                                        <div class="sub-role-card">
                                                            <span class="sub-role-name">{sub.title}</span>
                                                            <span class="sub-role-date">{sub.date}</span>
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        )}

                                        {exp.tags && (
                                            <div class="timeline-tags">
                                                {exp.tags.map(tag => <span class="tag">{tag}</span>)}
                                            </div>
                                        )}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>

                <!-- Yetkinlikler Panel -->
                <div class="cv-sub-section">
                    <div class="skills-languages-grid">
                        <div class="skills-panel">
                            <h4 class="sub-section-title">Uzmanlık Alanları</h4>
                            <div class="skills-list" id="skillsList">
                                {PROFILE_DATA.skills.map(sk => (
                                    <div class="skill-item">
                                        <div class="skill-info">
                                            <span class="skill-name">{sk.name}</span>
                                            <span class="skill-percentage">{sk.level}%</span>
                                        </div>
                                        <div class="skill-bar-bg">
                                            <div class="skill-bar-fill" data-level={sk.level}></div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                        <div class="languages-panel">
                            <h4 class="sub-section-title">Dil Yetkinlikleri</h4>
                            <div class="languages-list" id="languagesList">
                                {PROFILE_DATA.languages.map(lang => (
                                    <div class="language-card" style={`--lang-percent: ${lang.percent}%`}>
                                        <span class="language-name">{lang.name}</span>
                                        <span class="language-level">{lang.level}</span>
                                        <div class="language-bar"></div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Eğitim Geçmişi -->
                <div class="cv-sub-section">
                    <h4 class="sub-section-title education-title-center">Eğitim Geçmişi</h4>
                    <div class="education-grid" id="educationGrid">
                        {PROFILE_DATA.education.map(edu => (
                            <div class="education-card">
                                <span class="education-date">{edu.date}</span>
                                <h5 class="education-degree">{edu.degree}</h5>
                                <span class="education-school">{edu.school}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- İnteraktif Cephe Simülasyon Laboratuvarı -->
        <section id="simulasyon" class="section section-padding sim-lab-section">
            <div class="container">
                <div class="section-header">
                    <span class="section-tag">Dinamik Mühendislik Analizi</span>
                    <h3 class="section-title">Cephe Simülasyon Laboratuvarı</h3>
                    <div class="section-divider"></div>
                </div>

                <div class="sim-grid-layout">
                    <!-- Left: Interactive Canvas Visualizer -->
                    <div class="sim-canvas-container">
                        <canvas id="facadeCanvas"></canvas>
                        <div class="sim-panel-overlay">
                            <div class="sim-panel-title">Canlı FEM &amp; Termal Analiz</div>
                        </div>
                    </div>

                    <!-- Right: Control Deck & Telemetry -->
                    <div class="sim-control-deck">
                        <div class="sim-glass-card">
                            <h4 style="color: var(--text-primary); font-size: 1.2rem; font-weight: 700; margin-top: 0; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">Yük ve Çevre Kontrol Paneli</h4>
                            
                            <div class="sim-controls-wrapper">
                                <!-- Wind Speed Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Rüzgar Hızı (Wind Load)</span>
                                        <span class="sim-control-value" id="windVal">90 km/h</span>
                                    </div>
                                    <input type="range" id="windSlider" min="0" max="240" value="90" class="sim-range-input" />
                                </div>

                                <!-- Solar Radiation Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Güneş Radyasyonu (Solar Intensity)</span>
                                        <span class="sim-control-value" id="solarVal">400 W/m²</span>
                                    </div>
                                    <input type="range" id="solarSlider" min="0" max="1000" value="400" class="sim-range-input" />
                                </div>

                                <!-- Glass Type Control -->
                                <div class="sim-control-group">
                                    <label class="sim-control-label" for="glassSelect">Cam Kombinasyonu (Glass Type)</label>
                                    <select id="glassSelect" class="sim-select">
                                        <option value="single">Tek Kat Düz Cam (4mm) [U: 5.8, SHGC: 0.82]</option>
                                        <option value="double">Standart Çift Cam (24mm) [U: 2.7, SHGC: 0.70]</option>
                                        <option value="double-lowe" selected>Çift Cam Low-E (Argon) [U: 1.4, SHGC: 0.40]</option>
                                        <option value="triple-lowe">Üç Cam Low-E (Argon Dolgulu) [U: 0.8, SHGC: 0.32]</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Telemetry Gauges Dashboard -->
                        <div class="sim-dashboard-grid">
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Rüzgar Basıncı</span>
                                <span class="sim-stat-value" id="pressureVal">383</span>
                                <span class="sim-stat-unit">Pascal (Pa)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Panel Sehimi</span>
                                <span class="sim-stat-value" id="deflectionVal">3.2</span>
                                <span class="sim-stat-unit">Milimetre (mm)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Net Isı Transferi</span>
                                <span class="sim-stat-value" id="heatVal">160</span>
                                <span class="sim-stat-unit">Watt / m² (W)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Enerji Tasarrufu</span>
                                <span class="sim-stat-value" id="savingVal">51%</span>
                                <span class="sim-stat-unit">Tek Cama Kıyasla</span>
                            </div>
                        </div>

                        <!-- Status Alert Indicator -->
                        <div class="sim-status-badge status-safe" id="statusBadge">
                            <span class="sim-status-dot"></span>
                            <span id="statusText">Statik Limit: GÜVENLİ</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Client-side script logic for physical simulation -->
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const canvas = document.getElementById('facadeCanvas');
                if (!canvas) return;
                
                const ctx = canvas.getContext('2d');
                
                // Sliders
                const windSlider = document.getElementById('windSlider');
                const solarSlider = document.getElementById('solarSlider');
                const glassSelect = document.getElementById('glassSelect');
                
                // Values display
                const windVal = document.getElementById('windVal');
                const solarVal = document.getElementById('solarVal');
                const pressureVal = document.getElementById('pressureVal');
                const deflectionVal = document.getElementById('deflectionVal');
                const heatVal = document.getElementById('heatVal');
                const savingVal = document.getElementById('savingVal');
                
                const statusBadge = document.getElementById('statusBadge');
                const statusText = document.getElementById('statusText');
                
                // Glass properties database
                const GLASS_PROPS = {
                    'single': { u: 5.8, shgc: 0.82, E: 70000, t: 4, saving: 0 },
                    'double': { u: 2.7, shgc: 0.70, E: 70000, t: 12, saving: 45 },
                    'double-lowe': { u: 1.4, shgc: 0.40, E: 70000, t: 16, saving: 72 },
                    'triple-lowe': { u: 0.8, shgc: 0.32, E: 70000, t: 24, saving: 85 }
                };
                
                let particles = [];
                let animationFrameId;
                
                // Particle structure
                class WindParticle {
                    constructor() {
                        this.reset();
                        this.x = Math.random() * (canvas.width * 0.7);
                    }
                    
                    reset() {
                        this.x = -10;
                        this.y = Math.random() * canvas.height;
                        this.speed = 3 + Math.random() * 5;
                        this.length = 10 + Math.random() * 15;
                        this.opacity = 0.1 + Math.random() * 0.4;
                    }
                    
                    update(windSpeed) {
                        const speedMultiplier = windSpeed / 60;
                        this.x += this.speed * (speedMultiplier > 0.1 ? speedMultiplier : 0.1);
                        
                        // Particle collision with glass pane
                        const glassX = canvas.width * 0.72;
                        if (this.x >= glassX) {
                            // deflecting flow downwards/upwards
                            this.y += (this.y > canvas.height / 2 ? 2 : -2) * (windSpeed / 100);
                            this.x += 1; // force past threshold
                        }
                        
                        if (this.x > canvas.width || this.y < 0 || this.y > canvas.height) {
                            this.reset();
                        }
                    }
                    
                    draw() {
                        ctx.strokeStyle = `rgba(156, 163, 175, ${this.opacity})`;
                        ctx.lineWidth = 1;
                        ctx.beginPath();
                        ctx.moveTo(this.x, this.y);
                        ctx.lineTo(this.x - this.length, this.y);
                        ctx.stroke();
                    }
                }
                
                function resizeCanvas() {
                    const rect = canvas.getBoundingClientRect();
                    canvas.width = rect.width * window.devicePixelRatio;
                    canvas.height = rect.height * window.devicePixelRatio;
                    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
                    
                    // Initialize wind particles
                    particles = [];
                    const particleCount = Math.floor(rect.width / 15);
                    for (let i = 0; i < particleCount; i++) {
                        particles.push(new WindParticle());
                    }
                }
                
                resizeCanvas();
                window.addEventListener('resize', resizeCanvas);
                
                // Mouse interactive coordinates
                let mouseX = -100;
                let mouseY = -100;
                let isMouseOver = false;
                
                canvas.addEventListener('mousemove', (e) => {
                    const rect = canvas.getBoundingClientRect();
                    mouseX = e.clientX - rect.left;
                    mouseY = e.clientY - rect.top;
                    isMouseOver = true;
                });
                
                canvas.addEventListener('mouseleave', () => {
                    isMouseOver = false;
                });
                
                function drawLoop() {
                    const rect = canvas.getBoundingClientRect();
                    const w = rect.width;
                    const h = rect.height;
                    
                    ctx.clearRect(0, 0, w, h);
                    
                    // Current simulation inputs
                    const windSpeed = parseFloat(windSlider.value);
                    const solarRad = parseFloat(solarSlider.value);
                    const glassType = glassSelect.value;
                    const props = GLASS_PROPS[glassType];
                    
                    // Physics math calculations
                    const windSpeedMS = windSpeed / 3.6;
                    const pressure = 0.613 * windSpeedMS * windSpeedMS; // Pa
                    
                    // Deflection formula (exaggerated for visual display)
                    const deflectionScale = 0.04; 
                    const maxDeflectionPixels = (pressure * deflectionScale) / (props.t * 0.4);
                    const realDeflectionMM = (pressure * 0.008) / (props.t * 0.25);
                    
                    // Solar heat gain (W/m2)
                    const netHeatGain = (solarRad * props.shgc) + (20 * props.u); // radiation + ambient delta
                    
                    // Telemetry updates
                    windVal.innerText = `${windSpeed} km/h`;
                    solarVal.innerText = `${solarRad} W/m²`;
                    pressureVal.innerText = `${Math.round(pressure)} Pa`;
                    deflectionVal.innerText = realDeflectionMM.toFixed(1);
                    heatVal.innerText = Math.round(netHeatGain);
                    savingVal.innerText = `${props.saving}%`;
                    
                    // Status Badge Updates
                    statusBadge.className = 'sim-status-badge';
                    if (realDeflectionMM <= 10) {
                        statusBadge.classList.add('status-safe');
                        statusText.innerText = 'Statik Sınır: GÜVENLİ';
                    } else if (realDeflectionMM <= 18) {
                        statusBadge.classList.add('status-warning');
                        statusText.innerText = 'Statik Sınır: SEHİM LİMİTİNDE (L/300)';
                    } else {
                        statusBadge.classList.add('status-danger');
                        statusText.innerText = 'TEHLİKE: STATİK KAPASİTE AŞILDI (L/200)';
                    }
                    
                    // 1. Draw Grid Lines background
                    ctx.strokeStyle = 'var(--border-color)';
                    ctx.lineWidth = 0.5;
                    const gridSize = 40;
                    for (let x = 0; x < w; x += gridSize) {
                        ctx.beginPath();
                        ctx.moveTo(x, 0);
                        ctx.lineTo(x, h);
                        ctx.stroke();
                    }
                    for (let y = 0; y < h; y += gridSize) {
                        ctx.beginPath();
                        ctx.moveTo(0, y);
                        ctx.lineTo(w, y);
                        ctx.stroke();
                    }
                    
                    // 2. Update and draw wind particles
                    particles.forEach(p => {
                        p.update(windSpeed);
                        p.draw();
                    });
                    
                    // 3. Draw Solar ray paths
                    if (solarRad > 10) {
                        const rayCount = Math.floor(solarRad / 150) + 1;
                        ctx.lineWidth = 1.5;
                        for (let i = 0; i < rayCount; i++) {
                            const yStart = (h / rayCount) * i + 20;
                            const glassX = w * 0.72;
                            
                            // Sun ray path from top-left
                            const angle = 0.5; // rad
                            const xReach = yStart * Math.tan(angle);
                            const hitX = glassX - (realDeflectionMM * 0.3); // approximate bending offset
                            
                            ctx.strokeStyle = `rgba(212, 163, 115, ${0.1 + (solarRad/1500)})`;
                            ctx.beginPath();
                            ctx.moveTo(0, yStart - 40);
                            ctx.lineTo(hitX, yStart);
                            ctx.stroke();
                            
                            // Reflected beam
                            ctx.strokeStyle = `rgba(212, 163, 115, ${0.05 + (solarRad/3000)})`;
                            ctx.beginPath();
                            ctx.moveTo(hitX, yStart);
                            ctx.lineTo(hitX - 80, yStart - 40);
                            ctx.stroke();
                            
                            // Transmitted ray (shgc determined intensity)
                            ctx.strokeStyle = `rgba(255, 100, 100, ${0.1 * props.shgc})`;
                            ctx.beginPath();
                            ctx.moveTo(hitX, yStart);
                            ctx.lineTo(w, yStart + 20);
                            ctx.stroke();
                        }
                    }
                    
                    // 4. Draw Structural Concrete Floor Slabs (Top & Bottom)
                    ctx.fillStyle = 'var(--bg-tertiary)';
                    ctx.fillRect(w * 0.7, 0, w * 0.3, 40); // Top Slab
                    ctx.fillRect(w * 0.7, h - 40, w * 0.3, 40); // Bottom Slab
                    
                    ctx.strokeStyle = 'var(--border-color)';
                    ctx.lineWidth = 1.5;
                    ctx.strokeRect(w * 0.7, 0, w * 0.3, 40);
                    ctx.strokeRect(w * 0.7, h - 40, w * 0.3, 40);
                    
                    // 5. Draw Aluminum Anchor brackets
                    ctx.fillStyle = 'var(--text-muted)';
                    ctx.fillRect(w * 0.71, 40, 12, 20);
                    ctx.fillRect(w * 0.71, h - 60, 12, 20);
                    
                    // 6. Draw Bending Facade Unitized Glass Panel
                    const anchorTopY = 40;
                    const anchorBotY = h - 40;
                    const panelX = w * 0.72;
                    
                    ctx.beginPath();
                    ctx.moveTo(panelX, anchorTopY);
                    
                    // Draw cubic bezier curve to simulate elastic flexural bending profile
                    const ctrlX = panelX + maxDeflectionPixels;
                    const midY = (anchorTopY + anchorBotY) / 2;
                    ctx.bezierCurveTo(panelX, anchorTopY + 50, ctrlX, midY - 50, ctrlX, midY);
                    ctx.bezierCurveTo(ctrlX, midY + 50, panelX, anchorBotY - 50, panelX, anchorBotY);
                    
                    // Draw Glass thickness lines
                    ctx.strokeStyle = realDeflectionMM > 18 ? 'rgba(231, 76, 60, 0.8)' : 'var(--accent-color)';
                    ctx.lineWidth = props.t === 4 ? 3 : (props.t === 12 ? 6 : (props.t === 16 ? 8 : 11));
                    ctx.shadowColor = realDeflectionMM > 18 ? '#e74c3c' : 'var(--accent-color)';
                    ctx.shadowBlur = realDeflectionMM > 18 ? 8 : 2;
                    ctx.stroke();
                    ctx.shadowBlur = 0; // reset
                    
                    // 7. Draw stress heatmap overlay under deflection
                    if (windSpeed > 10) {
                        ctx.beginPath();
                        ctx.moveTo(panelX, anchorTopY);
                        ctx.bezierCurveTo(panelX, anchorTopY + 50, ctrlX, midY - 50, ctrlX, midY);
                        ctx.bezierCurveTo(ctrlX, midY + 50, panelX, anchorBotY - 50, panelX, anchorBotY);
                        
                        // Stress color gradient (red at center of span, fading towards supports)
                        const stressGrad = ctx.createLinearGradient(0, anchorTopY, 0, anchorBotY);
                        stressGrad.addColorStop(0, 'rgba(46, 204, 113, 0)');
                        stressGrad.addColorStop(0.3, `rgba(241, 196, 15, ${windSpeed / 300})`);
                        stressGrad.addColorStop(0.5, `rgba(231, 76, 60, ${windSpeed / 240})`);
                        stressGrad.addColorStop(0.7, `rgba(241, 196, 15, ${windSpeed / 300})`);
                        stressGrad.addColorStop(1, 'rgba(46, 204, 113, 0)');
                        
                        ctx.strokeStyle = stressGrad;
                        ctx.lineWidth = ctx.lineWidth * 0.4;
                        ctx.stroke();
                    }
                    
                    // 8. Draw Interactive Mouse Probe Tooltip (Simulated FEM Node lookup)
                    if (isMouseOver && mouseX < w * 0.75) {
                        // Get closest Y on panel bending line to calculate coordinates
                        const t = (mouseY - anchorTopY) / (anchorBotY - anchorTopY);
                        if (t >= 0 && t <= 1) {
                            // Bezier y formula logic
                            const bendOffset = 4 * t * (1 - t) * maxDeflectionPixels;
                            const nodeX = panelX + bendOffset;
                            
                            // Highlight node dot
                            ctx.fillStyle = 'var(--text-primary)';
                            ctx.beginPath();
                            ctx.arc(nodeX, mouseY, 5, 0, Math.PI * 2);
                            ctx.fill();
                            ctx.strokeStyle = 'var(--bg-primary)';
                            ctx.lineWidth = 1.5;
                            ctx.stroke();
                            
                            // Tooltip info window
                            const nodeStress = Math.round((windSpeed / 240) * 115 * 4 * t * (1 - t)); // MPa
                            const nodeDeflect = (4 * t * (1 - t) * realDeflectionMM).toFixed(2); // mm
                            
                            ctx.fillStyle = 'rgba(31, 41, 55, 0.95)';
                            ctx.strokeStyle = 'var(--border-color)';
                            ctx.lineWidth = 1;
                            
                            const tipW = 140;
                            const tipH = 55;
                            const tipX = Math.max(10, nodeX - tipW - 15);
                            const tipY = Math.min(h - tipH - 10, Math.max(10, mouseY - tipH / 2));
                            
                            ctx.fillRect(tipX, tipY, tipW, tipH);
                            ctx.strokeRect(tipX, tipY, tipW, tipH);
                            
                            ctx.fillStyle = 'var(--text-primary)';
                            ctx.font = 'bold 9px var(--font-primary)';
                            ctx.fillText(`KOORDİNAT: x:${Math.round(nodeX)}, y:${Math.round(mouseY)}`, tipX + 8, tipY + 14);
                            
                            ctx.fillStyle = 'var(--text-secondary)';
                            ctx.font = '8px var(--font-primary)';
                            ctx.fillText(`Gerilme (Stress): ${nodeStress} MPa`, tipX + 8, tipY + 28);
                            ctx.fillText(`Sehim (Deflection): ${nodeDeflect} mm`, tipX + 8, tipY + 40);
                        }
                    }
                    
                    animationFrameId = requestAnimationFrame(drawLoop);
                }
                
                drawLoop();
            });
        </script>

        <!-- Projeler Section -->
        <section id="projeler" class="section section-padding section-alt">
            <div class="container">
                <div class="section-header">
                    <span class="section-tag">Portfolyo</span>
                    <h3 class="section-title">Referans Projeler</h3>
                    <div class="section-divider"></div>
                </div>

                <!-- Project Category Filters -->
                <div class="project-filters">
                    <button class="project-filter-btn active" data-proj-filter="all">Tüm Projeler</button>
                    <button class="project-filter-btn" data-proj-filter="us">ABD (İmalat &amp; Tasarım)</button>
                    <button class="project-filter-btn" data-proj-filter="tr">Türkiye Projeleri</button>
                    <button class="project-filter-btn" data-proj-filter="facade">Cephe Tasarımı</button>
                </div>

                <!-- Projects Grid -->
                <div class="projects-grid" id="projectsGrid">
                    {PROFILE_DATA.projects.map((proj, idx) => {
                        const tagsStr = proj.tags.join(' ');
                        const isUS = proj.category === 'us';
                        return (
                            <div class="project-card reveal" data-category={proj.category} data-tags={tagsStr} style={`animation-delay: ${idx * 0.1}s`}>
                                <div>
                                    <div class="project-header">
                                        <div class="project-icon">
                                            {isUS ? (
                                                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            ) : (
                                                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round"/>
                                                    <path d="M9 3v18M21 9H3M21 15H3" stroke-linecap="round"/>
                                                </svg>
                                            )}
                                        </div>
                                        <span class="project-loc-tag">{proj.location}</span>
                                    </div>
                                    <h4 class="project-title">{proj.title}</h4>
                                    <p class="project-desc">{proj.description}</p>
                                </div>
                                <div class="project-footer">
                                    <span class="project-tech">{proj.facadeType}</span>
                                    <div class="timeline-tags">
                                        {proj.tags.map(t => <span class="tag">{t}</span>)}
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </section>
    </main>
</Layout>
