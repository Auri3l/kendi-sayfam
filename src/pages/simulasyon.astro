---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="Cephe Simülasyon Laboratuvarı | Ata Yiğit Telli" activePage="simulasyon" description="Rüzgar yükü ve güneş radyasyonu altında giydirme cephe panellerinin canlı statik sehim ve termal performans simülasyon laboratuvarı.">
    <main>
        <section class="section section-padding sim-lab-section" style="margin-top: 5rem; min-height: 90vh;">
            <div class="container">
                <div class="section-header">
                    <span class="section-tag">Dinamik Mühendislik Analizi</span>
                    <h3 class="section-title">Cephe Simülasyon Laboratuvarı</h3>
                    <div class="section-divider"></div>
                </div>

                <div class="sim-grid-layout">
                    <!-- Left: Interactive Canvas Visualizer -->
                    <div class="sim-canvas-container">
                        <canvas id="facadeCanvas"></canvas>
                        <div class="sim-panel-overlay">
                            <div class="sim-panel-title">Canlı 3D FEM &amp; Termal Analiz</div>
                        </div>
                        <div class="sim-fem-hud" id="femHUD">
                            <div class="hud-title">FEM DÜĞÜM ANALİZÖRÜ</div>
                            <div class="hud-row"><span class="hud-label">Düğüm (Node):</span> <span class="hud-value" id="hudNode">-</span></div>
                            <div class="hud-row"><span class="hud-label">Koordinat:</span> <span class="hud-value" id="hudCoord">-</span></div>
                            <div class="hud-row"><span class="hud-label">Sehim (Deflection):</span> <span class="hud-value" id="hudDeflect">-</span></div>
                            <div class="hud-row"><span class="hud-label">Gerilme (Stress):</span> <span class="hud-value" id="hudStress">-</span></div>
                        </div>
                    </div>

                    <!-- Right: Control Deck & Telemetry -->
                    <div class="sim-control-deck">
                        <div class="sim-glass-card">
                            <h4 style="color: var(--text-primary); font-size: 1.2rem; font-weight: 700; margin-top: 0; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">Yük ve Geometri Kontrol Paneli</h4>
                            
                            <div class="sim-controls-wrapper">
                                <!-- Wind Speed Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Rüzgar Hızı (Wind Speed)</span>
                                        <span class="sim-control-value" id="windVal">90 km/h</span>
                                    </div>
                                    <input type="range" id="windSlider" min="0" max="240" value="90" class="sim-range-input" />
                                </div>

                                <!-- Solar Radiation Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Güneş Radyasyonu (Solar Intensity)</span>
                                        <span class="sim-control-value" id="solarVal">400 W/m²</span>
                                    </div>
                                    <input type="range" id="solarSlider" min="0" max="1000" value="400" class="sim-range-input" />
                                </div>

                                <!-- Glass Width Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Cam Genişliği (Width - b)</span>
                                        <span class="sim-control-value" id="widthVal">1.50 m</span>
                                    </div>
                                    <input type="range" id="widthSlider" min="0.5" max="3.0" step="0.1" value="1.5" class="sim-range-input" />
                                </div>

                                <!-- Glass Height Control -->
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Cam Yüksekliği (Height - a)</span>
                                        <span class="sim-control-value" id="heightVal">3.00 m</span>
                                    </div>
                                    <input type="range" id="heightSlider" min="1.0" max="4.5" step="0.1" value="3.0" class="sim-range-input" />
                                </div>

                                <!-- Glass Type Control -->
                                <div class="sim-control-group">
                                    <label class="sim-control-label" for="glassSelect">Cam Kombinasyonu (Glass Type)</label>
                                    <select id="glassSelect" class="sim-select">
                                        <option value="single">Tek Kat Düz Cam (4mm) [U: 5.8, SHGC: 0.82]</option>
                                        <option value="double">Standart Çift Cam (24mm) [U: 2.7, SHGC: 0.70]</option>
                                        <option value="double-lowe" selected>Çift Cam Low-E (Argon) [U: 1.4, SHGC: 0.40]</option>
                                        <option value="triple-lowe">Üç Cam Low-E (Argon Dolgulu) [U: 0.8, SHGC: 0.32]</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Telemetry Gauges Dashboard -->
                        <div class="sim-dashboard-grid">
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Rüzgar Basıncı</span>
                                <span class="sim-stat-value" id="pressureVal">383</span>
                                <span class="sim-stat-unit">Pascal (Pa)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Panel Sehim Değeri</span>
                                <span class="sim-stat-value" id="deflectionVal">3.2</span>
                                <span class="sim-stat-unit">Milimetre (mm)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Isı İletim Hızı</span>
                                <span class="sim-stat-value" id="heatVal">160</span>
                                <span class="sim-stat-unit">Watt / m² (W)</span>
                            </div>
                            <div class="sim-stat-card">
                                <span class="sim-stat-label">Termal Verimlilik</span>
                                <span class="sim-stat-value" id="savingVal">51%</span>
                                <span class="sim-stat-unit">Tek Cama Göre</span>
                            </div>
                        </div>

                        <!-- Status Alert Indicator -->
                        <div class="sim-status-badge status-safe" id="statusBadge">
                            <span class="sim-status-dot"></span>
                            <span id="statusText">Statik Sınır: GÜVENLİ</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Client-side script logic for physical simulation -->
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const canvas = document.getElementById('facadeCanvas');
                if (!canvas) return;
                
                const ctx = canvas.getContext('2d');
                
                // Sliders
                const windSlider = document.getElementById('windSlider');
                const solarSlider = document.getElementById('solarSlider');
                const widthSlider = document.getElementById('widthSlider');
                const heightSlider = document.getElementById('heightSlider');
                const glassSelect = document.getElementById('glassSelect');
                
                // Values display
                const windVal = document.getElementById('windVal');
                const solarVal = document.getElementById('solarVal');
                const widthVal = document.getElementById('widthVal');
                const heightVal = document.getElementById('heightVal');
                const pressureVal = document.getElementById('pressureVal');
                const deflectionVal = document.getElementById('deflectionVal');
                const heatVal = document.getElementById('heatVal');
                const savingVal = document.getElementById('savingVal');
                
                const statusBadge = document.getElementById('statusBadge');
                const statusText = document.getElementById('statusText');
                
                // FEM HUD elements
                const hudNode = document.getElementById('hudNode');
                const hudCoord = document.getElementById('hudCoord');
                const hudDeflect = document.getElementById('hudDeflect');
                const hudStress = document.getElementById('hudStress');
                
                // Glass properties database
                const GLASS_PROPS = {
                    'single': { name: 'Tek Kat Düz Cam (4mm)', u: 5.8, shgc: 0.82, E: 70000, t: 4, saving: 0 },
                    'double': { name: 'Standart Çift Cam (24mm)', u: 2.7, shgc: 0.70, E: 70000, t: 7.56, saving: 45 },
                    'double-lowe': { name: 'Çift Cam Low-E (Argon)', u: 1.4, shgc: 0.40, E: 70000, t: 10.0, saving: 72 },
                    'triple-lowe': { name: 'Üç Cam Low-E (Argon Dolgulu)', u: 0.8, shgc: 0.32, E: 70000, t: 11.45, saving: 85 }
                };
                
                let particles = [];
                let animationFrameId;
                
                // 3D Wind Particle structure
                class WindParticle3D {
                    constructor() {
                        this.reset();
                        this.x3d = (Math.random() - 0.5) * 4.0; // random 3D x
                        this.y3d = (Math.random() - 0.5) * 4.0; // random 3D y
                    }
                    
                    reset() {
                        this.x3d = (Math.random() - 0.5) * 3.0;
                        this.y3d = (Math.random() - 0.5) * 4.0;
                        this.z3d = 2.5 + Math.random() * 2.0; // starts in front of glass
                        this.speed = 0.05 + Math.random() * 0.08;
                        this.opacity = 0.15 + Math.random() * 0.35;
                    }
                    
                    update(windSpeed) {
                        const speedMultiplier = windSpeed / 60;
                        this.z3d -= this.speed * (speedMultiplier > 0.1 ? speedMultiplier : 0.1);
                        
                        // If it passes behind the glass
                        if (this.z3d < -1.5) {
                            this.reset();
                        }
                    }
                }
                
                function resizeCanvas() {
                    const rect = canvas.getBoundingClientRect();
                    canvas.width = rect.width * window.devicePixelRatio;
                    canvas.height = rect.height * window.devicePixelRatio;
                    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
                    
                    // Initialize wind particles
                    particles = [];
                    const particleCount = 45;
                    for (let i = 0; i < particleCount; i++) {
                        particles.push(new WindParticle3D());
                    }
                }
                
                resizeCanvas();
                window.addEventListener('resize', resizeCanvas);
                
                // Mouse interactive coordinates
                let mouseX = -100;
                let mouseY = -100;
                let isMouseOver = false;
                
                canvas.addEventListener('mousemove', (e) => {
                    const rect = canvas.getBoundingClientRect();
                    mouseX = e.clientX - rect.left;
                    mouseY = e.clientY - rect.top;
                    isMouseOver = true;
                });
                
                canvas.addEventListener('mouseleave', () => {
                    isMouseOver = false;
                    hudNode.innerText = "-";
                    hudCoord.innerText = "-";
                    hudDeflect.innerText = "-";
                    hudStress.innerText = "-";
                });
                
                function drawLoop() {
                    const rect = canvas.getBoundingClientRect();
                    const w = rect.width;
                    const h = rect.height;
                    
                    ctx.clearRect(0, 0, w, h);
                    
                    // Current simulation inputs
                    const windSpeed = parseFloat(windSlider.value);
                    const solarRad = parseFloat(solarSlider.value);
                    const glassWidth = parseFloat(widthSlider.value);
                    const glassHeight = parseFloat(heightSlider.value);
                    const glassType = glassSelect.value;
                    const props = GLASS_PROPS[glassType];
                    
                    // Physics math calculations
                    const windSpeedMS = windSpeed / 3.6;
                    const pressure = 0.613 * windSpeedMS * windSpeedMS; // Pa
                    
                    // Flexural Rigidity D = E * t^3 / (12 * (1 - nu^2))
                    const E_Pa = props.E * 1e6; // Pa
                    const t_m = props.t / 1000; // m
                    const nu = 0.22; // Poisson ratio
                    const D = (E_Pa * Math.pow(t_m, 3)) / (12 * (1 - nu * nu));
                    
                    // Deflection formula for plate supported on 4 sides under uniform load:
                    const b_m = Math.min(glassWidth, glassHeight); // short span
                    const a_m = Math.max(glassWidth, glassHeight); // long span
                    
                    // Plate deflection factor approximation
                    const deflectionM = (5 * pressure * Math.pow(b_m, 4)) / (384 * D) * (1 / (1 + Math.pow(b_m / a_m, 4)));
                    const realDeflectionMM = deflectionM * 1000;
                    
                    // Exaggerate visually so the deflection shape is obvious
                    const maxDeflectionPixels = Math.min(80, realDeflectionMM * 4.5);
                    
                    // Solar heat gain (W/m2)
                    const netHeatGain = (solarRad * props.shgc) + (20 * props.u); // radiation + ambient delta
                    
                    // Telemetry updates
                    windVal.innerText = `${windSpeed} km/h`;
                    solarVal.innerText = `${solarRad} W/m²`;
                    widthVal.innerText = `${glassWidth.toFixed(2)} m`;
                    heightVal.innerText = `${glassHeight.toFixed(2)} m`;
                    pressureVal.innerText = `${Math.round(pressure)}`;
                    deflectionVal.innerText = realDeflectionMM.toFixed(2);
                    heatVal.innerText = Math.round(netHeatGain);
                    savingVal.innerText = `${props.saving}%`;
                    
                    // Status Badge Updates (Deflection limit L/300 where L is short span b_m!)
                    const limitSpan = (b_m * 1000) / 300; // mm
                    const dangerLimit = (b_m * 1000) / 200; // mm
                    
                    statusBadge.className = 'sim-status-badge';
                    if (realDeflectionMM <= limitSpan) {
                        statusBadge.classList.add('status-safe');
                        statusText.innerText = `Statik Limit: GÜVENLİ (Limit L/300: ${limitSpan.toFixed(1)} mm)`;
                    } else if (realDeflectionMM <= dangerLimit) {
                        statusBadge.classList.add('status-warning');
                        statusText.innerText = `UYARI: SEHİM LİMİTİ AŞILDI (L/300: ${limitSpan.toFixed(1)} mm)`;
                    } else {
                        statusBadge.classList.add('status-danger');
                        statusText.innerText = `TEHLİKE: YAPISAL KAPASİTE YETERSİZ (L/200: ${dangerLimit.toFixed(1)} mm)`;
                    }
                    
                    // 1. Draw Grid Lines background
                    ctx.strokeStyle = 'rgba(255,255,255,0.02)';
                    ctx.lineWidth = 0.5;
                    const gridSize = 40;
                    for (let x = 0; x < w; x += gridSize) {
                        ctx.beginPath();
                        ctx.moveTo(x, 0);
                        ctx.lineTo(x, h);
                        ctx.stroke();
                    }
                    for (let y = 0; y < h; y += gridSize) {
                        ctx.beginPath();
                        ctx.moveTo(0, y);
                        ctx.lineTo(w, y);
                        ctx.stroke();
                    }
                    
                    // --- 3D PROJECTOR UTILITY ---
                    // Isometric projection angles
                    const pitch = 0.45; // forward tilt
                    const yaw = -0.55;  // side rotation
                    const centerX = w * 0.48;
                    const centerY = h * 0.52;
                    const scale3d = 95; // scaling factor for 3D coordinates
                    
                    function project3D(x3d, y3d, z3d) {
                        // 1. Rotate around Y (yaw)
                        const rx = x3d * Math.cos(yaw) - z3d * Math.sin(yaw);
                        const rz = x3d * Math.sin(yaw) + z3d * Math.cos(yaw);
                        const ry = y3d;
                        
                        // 2. Rotate around X (pitch)
                        const px = rx;
                        const py = ry * Math.cos(pitch) - rz * Math.sin(pitch);
                        const pz = ry * Math.sin(pitch) + rz * Math.cos(pitch);
                        
                        // Project to 2D canvas coordinates
                        return {
                            x: centerX + px * scale3d,
                            y: centerY - py * scale3d,
                            depth: pz
                        };
                    }
                    
                    // 2. Update and Draw 3D Wind Flow Particles
                    particles.forEach(p => {
                        p.update(windSpeed);
                        
                        // Project particle path endpoints
                        const pt1 = project3D(p.x3d, p.y3d, p.z3d);
                        const pt2 = project3D(p.x3d, p.y3d, p.z3d + 0.15); // short trail
                        
                        // Fade particles based on depth/clipping
                        if (pt1.x >= 0 && pt1.x <= w && pt1.y >= 0 && pt1.y <= h) {
                            ctx.strokeStyle = `rgba(156, 163, 175, ${p.opacity})`;
                            ctx.lineWidth = 1;
                            ctx.beginPath();
                            ctx.moveTo(pt1.x, pt1.y);
                            ctx.lineTo(pt2.x, pt2.y);
                            ctx.stroke();
                        }
                    });
                    
                    // 3. Draw 3D Concrete Floor Slabs (Behind/Under the panel)
                    ctx.fillStyle = 'rgba(47, 50, 58, 0.45)';
                    ctx.strokeStyle = 'var(--border-color)';
                    ctx.lineWidth = 1;
                    
                    // We render top and bottom floor slabs as 3D boxes
                    const slabW = glassWidth + 0.6;
                    const slabD = 0.8;
                    const halfH = glassHeight / 2;
                    
                    // Bottom Slab corners (drawn in 3D)
                    const bSlabNodes = [
                        project3D(-slabW/2, -halfH, -slabD), // 0
                        project3D(slabW/2, -halfH, -slabD),  // 1
                        project3D(slabW/2, -halfH, 0),       // 2
                        project3D(-slabW/2, -halfH, 0),      // 3
                        project3D(-slabW/2, -halfH - 0.25, -slabD), // 4
                        project3D(slabW/2, -halfH - 0.25, -slabD),  // 5
                        project3D(slabW/2, -halfH - 0.25, 0),       // 6
                        project3D(-slabW/2, -halfH - 0.25, 0)       // 7
                    ];
                    
                    // Draw Bottom Slab
                    ctx.beginPath();
                    ctx.moveTo(bSlabNodes[4].x, bSlabNodes[4].y);
                    ctx.lineTo(bSlabNodes[5].x, bSlabNodes[5].y);
                    ctx.lineTo(bSlabNodes[6].x, bSlabNodes[6].y);
                    ctx.lineTo(bSlabNodes[7].x, bSlabNodes[7].y);
                    ctx.closePath();
                    ctx.fill();
                    ctx.stroke();
                    
                    ctx.beginPath();
                    ctx.moveTo(bSlabNodes[7].x, bSlabNodes[7].y);
                    ctx.lineTo(bSlabNodes[6].x, bSlabNodes[6].y);
                    ctx.lineTo(bSlabNodes[2].x, bSlabNodes[2].y);
                    ctx.lineTo(bSlabNodes[3].x, bSlabNodes[3].y);
                    ctx.closePath();
                    ctx.fill();
                    ctx.stroke();
                    
                    // Top Slab corners
                    const tSlabNodes = [
                        project3D(-slabW/2, halfH + 0.25, -slabD), // 0
                        project3D(slabW/2, halfH + 0.25, -slabD),  // 1
                        project3D(slabW/2, halfH + 0.25, 0),       // 2
                        project3D(-slabW/2, halfH + 0.25, 0),      // 3
                        project3D(-slabW/2, halfH, -slabD),        // 4
                        project3D(slabW/2, halfH, -slabD),         // 5
                        project3D(slabW/2, halfH, 0),              // 6
                        project3D(-slabW/2, halfH, 0)              // 7
                    ];
                    
                    // Draw Top Slab
                    ctx.beginPath();
                    ctx.moveTo(tSlabNodes[4].x, tSlabNodes[4].y);
                    ctx.lineTo(tSlabNodes[5].x, tSlabNodes[5].y);
                    ctx.lineTo(tSlabNodes[6].x, tSlabNodes[6].y);
                    ctx.lineTo(tSlabNodes[7].x, tSlabNodes[7].y);
                    ctx.closePath();
                    ctx.fill();
                    ctx.stroke();
                    
                    ctx.beginPath();
                    ctx.moveTo(tSlabNodes[7].x, tSlabNodes[7].y);
                    ctx.lineTo(tSlabNodes[6].x, tSlabNodes[6].y);
                    ctx.lineTo(tSlabNodes[2].x, tSlabNodes[2].y);
                    ctx.lineTo(tSlabNodes[3].x, tSlabNodes[3].y);
                    ctx.closePath();
                    ctx.fill();
                    ctx.stroke();
                    
                    // 4. Generate 3D Glass Surface Grid Mesh (11x11 Node grid)
                    const gridDivs = 10;
                    const meshNodes = []; // 2D array of projected nodes
                    let closestNode = null;
                    let minDist = 99999;
                    
                    for (let i = 0; i <= gridDivs; i++) {
                        meshNodes[i] = [];
                        const u = i / gridDivs; // width ratio [0, 1]
                        const x3d = (u - 0.5) * glassWidth;
                        
                        for (let j = 0; j <= gridDivs; j++) {
                            const v = j / gridDivs; // height ratio [0, 1]
                            const y3d = (v - 0.5) * glassHeight;
                            
                            // Deflection shape (Simply supported plate formula shape: sin(u*pi) * sin(v*pi))
                            const nodeDeflectRatio = Math.sin(u * Math.PI) * Math.sin(v * Math.PI);
                            const nodeDeflectMM = nodeDeflectRatio * realDeflectionMM;
                            
                            // Visual out-of-plane deflection (along Z axis)
                            // We convert the mm deflection to 3D Z coordinate offset
                            const z3dOffset = -(nodeDeflectRatio * maxDeflectionPixels) / scale3d;
                            
                            const pt2d = project3D(x3d, y3d, z3dOffset);
                            
                            // Calculate local stress (MPa) - max stress is at the center span
                            const nodeStress = Math.round((windSpeed / 240) * 115 * nodeDeflectRatio);
                            
                            meshNodes[i][j] = {
                                px: pt2d.x,
                                py: pt2d.y,
                                stress: nodeStress,
                                deflect: nodeDeflectMM,
                                u: u,
                                v: v,
                                x3d: x3d,
                                y3d: y3d
                            };
                            
                            // Inspect closest node under mouse
                            if (isMouseOver) {
                                const dist = Math.hypot(pt2d.x - mouseX, pt2d.y - mouseY);
                                if (dist < minDist && dist < 22) {
                                    minDist = dist;
                                    closestNode = { i, j, ...meshNodes[i][j] };
                                }
                            }
                        }
                    }
                    
                    // 5. Draw 3D Stress Heatmap Mesh faces
                    for (let i = 0; i < gridDivs; i++) {
                        for (let j = 0; j < gridDivs; j++) {
                            const n00 = meshNodes[i][j];
                            const n10 = meshNodes[i+1][j];
                            const n11 = meshNodes[i+1][j+1];
                            const n01 = meshNodes[i][j+1];
                            
                            // Average stress ratio of this quad cell
                            const avgRatio = (n00.deflect + n10.deflect + n11.deflect + n01.deflect) / (4 * (realDeflectionMM || 1));
                            
                            // Interpolate color: Green (safe, 0) -> Yellow (0.5) -> Red (danger, 1)
                            const r = Math.min(255, Math.floor(255 * avgRatio * 2));
                            const g = Math.min(255, Math.floor(255 * (1 - avgRatio) * 1.5));
                            const b = 50;
                            
                            // Base color fill with high-tech semi-transparency
                            ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${0.15 + avgRatio * 0.35})`;
                            
                            ctx.beginPath();
                            ctx.moveTo(n00.px, n00.py);
                            ctx.lineTo(n10.px, n10.py);
                            ctx.lineTo(n11.px, n11.py);
                            ctx.lineTo(n01.px, n01.py);
                            ctx.closePath();
                            ctx.fill();
                            
                            // Quad cell border grid lines
                            ctx.strokeStyle = realDeflectionMM > dangerLimit ? 'rgba(231, 76, 60, 0.15)' : 'rgba(255, 255, 255, 0.08)';
                            ctx.lineWidth = 0.5;
                            ctx.stroke();
                        }
                    }
                    
                    // 6. Draw 3D Frame Mullion Borders (Giydirme Cephe Alüminyum Profili)
                    ctx.strokeStyle = 'var(--text-muted)';
                    ctx.lineWidth = 3;
                    
                    // Left border profile
                    ctx.beginPath();
                    ctx.moveTo(meshNodes[0][0].px, meshNodes[0][0].py);
                    for (let j = 1; j <= gridDivs; j++) ctx.lineTo(meshNodes[0][j].px, meshNodes[0][j].py);
                    ctx.stroke();
                    
                    // Right border profile
                    ctx.beginPath();
                    ctx.moveTo(meshNodes[gridDivs][0].px, meshNodes[gridDivs][0].py);
                    for (let j = 1; j <= gridDivs; j++) ctx.lineTo(meshNodes[gridDivs][j].px, meshNodes[gridDivs][j].py);
                    ctx.stroke();
                    
                    // Top border profile
                    ctx.beginPath();
                    ctx.moveTo(meshNodes[0][gridDivs].px, meshNodes[0][gridDivs].py);
                    for (let i = 1; i <= gridDivs; i++) ctx.lineTo(meshNodes[i][gridDivs].px, meshNodes[i][gridDivs].py);
                    ctx.stroke();
                    
                    // Bottom border profile
                    ctx.beginPath();
                    ctx.moveTo(meshNodes[0][0].px, meshNodes[0][0].py);
                    for (let i = 1; i <= gridDivs; i++) ctx.lineTo(meshNodes[i][0].px, meshNodes[i][0].py);
                    ctx.stroke();
                    
                    // 7. Draw Solar Ray path (drawn in 3D projection)
                    if (solarRad > 10) {
                        const hitNode = meshNodes[Math.floor(gridDivs/2)][Math.floor(gridDivs/2)];
                        
                        // Ray coming from top-left front 3D coordinate to center node
                        const sunSource3D = { x3d: -glassWidth * 1.5, y3d: glassHeight * 1.5, z3d: 2.0 };
                        const sunSourcePt = project3D(sunSource3D.x3d, sunSource3D.y3d, sunSource3D.z3d);
                        
                        ctx.lineWidth = 2.0;
                        ctx.strokeStyle = `rgba(212, 163, 115, ${0.25 + (solarRad/1500)})`;
                        ctx.shadowColor = 'var(--accent-color)';
                        ctx.shadowBlur = 4;
                        
                        ctx.beginPath();
                        ctx.moveTo(sunSourcePt.x, sunSourcePt.y);
                        ctx.lineTo(hitNode.px, hitNode.py);
                        ctx.stroke();
                        ctx.shadowBlur = 0; // reset
                        
                        // Reflected Ray
                        const reflectPt = project3D(-glassWidth * 2.5, glassHeight * 1.0, 3.5);
                        ctx.strokeStyle = `rgba(212, 163, 115, ${0.1 + (solarRad/3000)})`;
                        ctx.beginPath();
                        ctx.moveTo(hitNode.px, hitNode.py);
                        ctx.lineTo(reflectPt.x, reflectPt.y);
                        ctx.stroke();
                        
                        // Transmitted Ray (behind the glass panel)
                        const transmitPt = project3D(glassWidth * 0.8, -glassHeight * 0.6, -1.5);
                        ctx.strokeStyle = `rgba(255, 100, 100, ${0.15 * props.shgc})`;
                        ctx.beginPath();
                        ctx.moveTo(hitNode.px, hitNode.py);
                        ctx.lineTo(transmitPt.x, transmitPt.y);
                        ctx.stroke();
                    }
                    
                    // 8. Dynamic interactive tooltip node selection (FEM Crosshair HUD)
                    if (closestNode) {
                        // Highlight target node
                        ctx.fillStyle = 'var(--text-primary)';
                        ctx.beginPath();
                        ctx.arc(closestNode.px, closestNode.py, 6, 0, Math.PI * 2);
                        ctx.fill();
                        ctx.strokeStyle = 'var(--bg-primary)';
                        ctx.lineWidth = 2;
                        ctx.stroke();
                        
                        // Draw HUD telemetry update
                        hudNode.innerText = `#${closestNode.i}_${closestNode.j}`;
                        hudCoord.innerText = `x: ${closestNode.x3d.toFixed(2)}m, y: ${closestNode.y3d.toFixed(2)}m`;
                        hudDeflect.innerText = `${closestNode.deflect.toFixed(2)} mm`;
                        hudStress.innerText = `${closestNode.stress} MPa`;
                        
                        // Draw horizontal/vertical guidelines
                        ctx.strokeStyle = 'rgba(255, 255, 255, 0.25)';
                        ctx.lineWidth = 1;
                        ctx.setLineDash([4, 4]);
                        
                        ctx.beginPath();
                        ctx.moveTo(closestNode.px, 0);
                        ctx.lineTo(closestNode.px, h);
                        ctx.moveTo(0, closestNode.py);
                        ctx.lineTo(w, closestNode.py);
                        ctx.stroke();
                        ctx.setLineDash([]); // reset
                    }
                    
                    // 9. Simple 2D Dimensions indicator on the side
                    ctx.fillStyle = 'var(--text-muted)';
                    ctx.font = 'bold 9px var(--font-primary)';
                    ctx.fillText(`GEOMETRİ: ${glassWidth.toFixed(2)}m x ${glassHeight.toFixed(2)}m`, 20, 20);
                    ctx.fillText(`EN/BOY ORANI: 1 : ${(glassHeight/glassWidth).toFixed(1)}`, 20, 32);
                    
                    animationFrameId = requestAnimationFrame(drawLoop);
                }
                
                drawLoop();
            });
        </script>
    </main>
</Layout>

