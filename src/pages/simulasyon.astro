                                    <tr><td>S-11</td><td>Su Yalıtımı Çift Bileşen Toz Çimento Kısmı</td><td id="outWaterproofPowder">-</td><td>kg</td></tr>
                                    <tr><td>S-12</td><td>Pah Güçlendirme Yalıtım Derz Filesi Alanı</td><td id="outWaterproofMesh">-</td><td>m²</td></tr>
                                    <tr><td>S-13</td><td>Köşe Elastik Su Yalıtımı Pah Bandı Metrajı</td><td id="outWaterproofBand">-</td><td>mt</td></tr>
                                    <tr><td>S-14</td><td>Zemin Tozuma Önleyici Akrilik Astar Miktarı</td><td id="outPrimerWeight">-</td><td>kg</td></tr>
                                    <tr><td>S-15</td><td>Net Seramik Kaplama Alanı (Zemin + Duvar)</td><td id="outTileArea">-</td><td>m²</td></tr>
                                    <tr><td>S-16</td><td>Gerekli Seramik Paketi Sayısı</td><td id="outTileBoxes">-</td><td>Kutu</td></tr>
                                    <tr><td>S-17</td><td>Seramik Çimento Esaslı Yapıştırıcı Torba Sayısı</td><td id="outTileAdhesive">-</td><td>Torba (25kg)</td></tr>
                                    <tr><td>S-18</td><td>Seramik Derz Dolgusu Malzemesi</td><td id="outTileGrout">-</td><td>Torba (5kg)</td></tr>
                                    <tr><td>S-19</td><td>Seramik Hizalama Derz Artısı (Derz Haçı) Sayısı</td><td id="outTileSpacers">-</td><td>Adet</td></tr>
