---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Simülasyon Sayfası | Ata Yiğit Telli" activePage="simulasyon" description="Simülasyon sayfası bakım aşamasındadır.">
    <main class="under-construction">
        <section class="section section-padding" style="margin-top: 5rem; min-height: 90vh; display: flex; align-items: center; justify-content: center;">
            <div class="under-construction-container" style="text-align: center;">
                <h2 style="font-size: 2rem; color: var(--text-primary); margin-bottom: 1rem;">Simülasyon Sayfası Bakım Aşamasındadır</h2>
                <p style="font-size: 1.2rem; color: var(--text-secondary);">Bu sayfa şu anda geliştirme aşamasındadır. Lütfen daha sonra yeniden ziyaret edin.</p>
            </div>
        </section>
    </main>
</Layout>
