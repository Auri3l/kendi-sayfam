---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Layout title="Mühendislik Simülasyon & Metraj Portalı | Ata Yiğit Telli" activePage="simulasyon" description="Canlı 3D FEM cephe bükülme simülasyonu ile kaba inşaat, ince inşaat, duvar, sıva, şap, yalıtım ve seramik malzeme metrajı hesaplama araçları.">
    <main>
        <section class="section section-padding sim-lab-section" style="margin-top: 5rem; min-height: 90vh;">
            <div class="container">
                <div class="section-header">
                    <span class="section-tag">İnteraktif Hesaplama Portalı</span>
                    <h3 class="section-title">Mühendislik Simülasyon &amp; Metraj Laboratuvarı</h3>
                    <div class="section-divider"></div>
                </div>

                <!-- Glassmorphic Navigation Tabs Selector -->
                <div class="sim-tabs-container">
                    <button class="sim-tab-btn active" data-tab="fem">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 2 7 12 12 22 7 12 2 12 22"/><line x1="2" y1="17" x2="12" y2="22"/><line x1="22" y1="17" x2="12" y2="22"/><line x1="2" y1="12" x2="12" y2="17"/><line x1="22" y1="12" x2="12" y2="17"/></svg>
                        3D FEM Analiz
                    </button>
                    <button class="sim-tab-btn" data-tab="cephe">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
                        Cephe Metrajı
                    </button>
                    <button class="sim-tab-btn" data-tab="beton">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Beton &amp; Kalıp
                    </button>
                    <button class="sim-tab-btn" data-tab="duvar">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round"/><path d="M3 9h18M3 15h18M9 9v12M15 3v6M9 3v6M15 15v6"/></svg>
                        Duvar &amp; Sıva
                    </button>
                    <button class="sim-tab-btn" data-tab="sap">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 11h8M12 7v8"/></svg>
                        Şap, Yalıtım &amp; Seramik
                    </button>
                </div>

                <!-- TAB 1: 3D FEM ANALYSIS -->
                <div class="sim-tab-panel active" id="tab-fem">
                    <div class="sim-grid-layout">
                        <!-- Left: Interactive Canvas Visualizer -->
                        <div class="sim-canvas-container">
                            <canvas id="facadeCanvas"></canvas>
                            <div class="sim-panel-overlay">
                                <div class="sim-panel-title">Canlı 3D FEM &amp; Termal Analiz</div>
                            </div>
                            <div class="sim-fem-hud" id="femHUD">
                                <div class="hud-title">FEM DÜĞÜM ANALİZÖRÜ</div>
                                <div class="hud-row"><span class="hud-label">Düğüm (Node):</span> <span class="hud-value" id="hudNode">-</span></div>
                                <div class="hud-row"><span class="hud-label">Koordinat:</span> <span class="hud-value" id="hudCoord">-</span></div>
                                <div class="hud-row"><span class="hud-label">Sehim (Deflection):</span> <span class="hud-value" id="hudDeflect">-</span></div>
                                <div class="hud-row"><span class="hud-label">Gerilme (Stress):</span> <span class="hud-value" id="hudStress">-</span></div>
                            </div>
                        </div>

                        <!-- Right: Control Deck & Telemetry -->
                        <div class="sim-control-deck">
                            <div class="sim-glass-card">
                                <h4 style="color: var(--text-primary); font-size: 1.2rem; font-weight: 700; margin-top: 0; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">Yük ve Geometri Kontrol Paneli</h4>
                                
                                <div class="sim-controls-wrapper">
                                    <div class="sim-control-group">
                                        <div class="sim-control-label-row">
                                            <span class="sim-control-label">Rüzgar Hızı (Wind Speed)</span>
                                            <span class="sim-control-value" id="windVal">90 km/h</span>
                                        </div>
                                        <input type="range" id="windSlider" min="0" max="240" value="90" class="sim-range-input" />
                                    </div>

                                    <div class="sim-control-group">
                                        <div class="sim-control-label-row">
                                            <span class="sim-control-label">Güneş Radyasyonu (Solar Intensity)</span>
                                            <span class="sim-control-value" id="solarVal">400 W/m²</span>
                                        </div>
                                        <input type="range" id="solarSlider" min="0" max="1000" value="400" class="sim-range-input" />
                                    </div>

                                    <div class="sim-control-group">
                                        <div class="sim-control-label-row">
                                            <span class="sim-control-label">Cam Genişliği (Width - b)</span>
                                            <span class="sim-control-value" id="widthVal">1.50 m</span>
                                        </div>
                                        <input type="range" id="widthSlider" min="0.5" max="3.0" step="0.1" value="1.5" class="sim-range-input" />
                                    </div>

                                    <div class="sim-control-group">
                                        <div class="sim-control-label-row">
                                            <span class="sim-control-label">Cam Yüksekliği (Height - a)</span>
                                            <span class="sim-control-value" id="heightVal">3.00 m</span>
                                        </div>
                                        <input type="range" id="heightSlider" min="1.0" max="4.5" step="0.1" value="3.0" class="sim-range-input" />
                                    </div>

                                    <div class="sim-control-group">
                                        <label class="sim-control-label" for="glassSelect">Cam Kombinasyonu (Glass Type)</label>
                                        <select id="glassSelect" class="sim-select">
                                            <option value="single">Tek Kat Düz Cam (4mm) [U: 5.8, SHGC: 0.82]</option>
                                            <option value="double">Standart Çift Cam (24mm) [U: 2.7, SHGC: 0.70]</option>
                                            <option value="double-lowe" selected>Çift Cam Low-E (Argon) [U: 1.4, SHGC: 0.40]</option>
                                            <option value="triple-lowe">Üç Cam Low-E (Argon Dolgulu) [U: 0.8, SHGC: 0.32]</option>
                                        </select>
                                    </div>

                                    <button type="button" class="btn btn-primary calc-btn" id="btnCalcFEM" style="width: 100%; margin-top: 0.5rem; justify-content: center; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 2 7 12 12 22 7 12 2 12 22"/><line x1="2" y1="17" x2="12" y2="22"/><line x1="22" y1="17" x2="12" y2="22"/><line x1="2" y1="12" x2="12" y2="17"/><line x1="22" y1="12" x2="12" y2="17"/></svg>
                                        ⚡ 3D FEM Analizini Yeniden Hesapla
                                    </button>
                                </div>
                            </div>

                            <!-- Telemetry Gauges Dashboard -->
                            <div class="sim-dashboard-grid">
                                <div class="sim-stat-card">
                                    <span class="sim-stat-label">Rüzgar Basıncı</span>
                                    <span class="sim-stat-value" id="pressureVal">383</span>
                                    <span class="sim-stat-unit">Pascal (Pa)</span>
                                </div>
                                <div class="sim-stat-card">
                                    <span class="sim-stat-label">Panel Sehim Değeri</span>
                                    <span class="sim-stat-value" id="deflectionVal">3.2</span>
                                    <span class="sim-stat-unit">Milimetre (mm)</span>
                                </div>
                                <div class="sim-stat-card">
                                    <span class="sim-stat-label">Isı İletim Hızı</span>
                                    <span class="sim-stat-value" id="heatVal">160</span>
                                    <span class="sim-stat-unit">Watt / m² (W)</span>
                                </div>
                                <div class="sim-stat-card">
                                    <span class="sim-stat-label">Termal Verimlilik</span>
                                    <span class="sim-stat-value" id="savingVal">51%</span>
                                    <span class="sim-stat-unit">Tek Cama Göre</span>
                                </div>
                            </div>

                            <!-- Status Alert Indicator -->
                            <div class="sim-status-badge status-safe" id="statusBadge">
                                <span class="sim-status-dot"></span>
                                <span id="statusText">Statik Sınır: GÜVENLİ</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 2: FACADE QUANTITY ESTIMATOR (10 METRICS) -->
                <div class="sim-tab-panel" id="tab-cephe">
                    <div class="metraj-grid">
                        <div class="metraj-controls-panel sim-glass-card">
                            <h4 class="metraj-panel-title">Cephe Genel Girdileri</h4>
                            <div class="sim-controls-wrapper">
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Bina Cephe Genişliği</span>
                                        <span class="sim-control-value" id="inpFacWidthVal">30 m</span>
                                    </div>
                                    <input type="range" id="inpFacWidth" min="10" max="150" value="30" step="5" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Bina Cephe Yüksekliği</span>
                                        <span class="sim-control-value" id="inpFacHeightVal">45 m</span>
                                    </div>
                                    <input type="range" id="inpFacHeight" min="5" max="120" value="45" step="5" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Tipik Panel Modül Genişliği</span>
                                        <span class="sim-control-value" id="inpPanWidthVal">1.50 m</span>
                                    </div>
                                    <input type="range" id="inpPanWidth" min="1.0" max="2.4" value="1.5" step="0.05" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Tipik Panel Modül Yüksekliği</span>
                                        <span class="sim-control-value" id="inpPanHeightVal">3.50 m</span>
                                    </div>
                                    <input type="range" id="inpPanHeight" min="2.0" max="4.5" value="3.5" step="0.05" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Kat Sayısı (Ankraj Katsayısı İçin)</label>
                                    <input type="number" id="inpFloorCount" value="12" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Profil Birim Ağırlığı (Düşey/Mullion - kg/m)</label>
                                    <input type="number" id="inpMullionWeight" value="4.2" step="0.1" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Profil Birim Ağırlığı (Yatay/Transom - kg/m)</label>
                                    <input type="number" id="inpTransomWeight" value="3.1" step="0.1" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Cam Kombinasyonu Eşdeğer Kalınlığı</label>
                                    <select id="inpGlassThk" class="sim-select">
                                        <option value="4">4 mm Tek Kat Cam</option>
                                        <option value="8" selected>6 + 12 + 6 mm Çift Cam (8mm Cam Ağırlığı)</option>
                                        <option value="12">8 + 16 + 8 mm Çift Cam (12mm Cam Ağırlığı)</option>
                                        <option value="16">10 + 16 + 10 mm Çift Cam (16mm Cam Ağırlığı)</option>
                                    </select>
                                </div>

                                <button type="button" class="btn btn-primary calc-btn" id="btnCalcCephe" style="width: 100%; margin-top: 0.5rem; justify-content: center; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 2v4M8 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/></svg>
                                    ⚡ Cephe Metrajını Hesapla
                                </button>
                            </div>
                        </div>
                        <div class="metraj-table-panel sim-glass-card">
                            <h4 class="metraj-panel-title">Cephe Malzeme Metraj Tablosu (Poz Listesi)</h4>
                            <table class="metraj-table">
                                <thead>
                                    <tr>
                                        <th>Poz No</th>
                                        <th>Açıklama (Material Item)</th>
                                        <th>Metraj Miktarı</th>
                                        <th>Birim</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>C-01</td><td>Toplam Modüler Cephe Paneli Sayısı</td><td id="outPanCount">-</td><td>Adet</td></tr>
                                    <tr><td>C-02</td><td>Net Cam Kaplama Alanı</td><td id="outGlassArea">-</td><td>m²</td></tr>
                                    <tr><td>C-03</td><td>Toplam Cam Ağırlığı</td><td id="outGlassWeight">-</td><td>kg</td></tr>
                                    <tr><td>C-04</td><td>Düşey Alüminyum Profil (Mullion) Toplam Metrajı</td><td id="outMullionLen">-</td><td>mt</td></tr>
                                    <tr><td>C-05</td><td>Yatay Alüminyum Profil (Transom) Toplam Metrajı</td><td id="outTransomLen">-</td><td>mt</td></tr>
                                    <tr><td>C-06</td><td>Toplam Alüminyum Profil Ağırlığı</td><td id="outAluWeight">-</td><td>kg</td></tr>
                                    <tr><td>C-07</td><td>Taşıyıcı T-Ankraj Ankraj Braketi Adeti</td><td id="outAnchorCount">-</td><td>Adet</td></tr>
                                    <tr><td>C-08</td><td>Yatay Profil T-Bağlantı Aparatları Sayısı</td><td id="outTConnCount">-</td><td>Adet</td></tr>
                                    <tr><td>C-09</td><td>Sızdırmazlık EPDM Cam Fitil Toplam Metrajı</td><td id="outEPDMLen">-</td><td>mt</td></tr>
                                    <tr><td>C-10</td><td>Panel Birleşim Akustik Sosis Derz Silikonu Adedi (600ml)</td><td id="outSiliconeCount">-</td><td>Adet</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TAB 3: CONCRETE & FORMWORK ESTIMATOR (10 METRICS) -->
                <div class="sim-tab-panel" id="tab-beton">
                    <div class="metraj-grid">
                        <div class="metraj-controls-panel sim-glass-card">
                            <h4 class="metraj-panel-title">Betonarme Yapı Girdileri</h4>
                            <div class="sim-controls-wrapper">
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Döşeme Uzunluğu</span>
                                        <span class="sim-control-value" id="inpSlabLenVal">25 m</span>
                                    </div>
                                    <input type="range" id="inpSlabLen" min="5" max="100" value="25" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Döşeme Genişliği</span>
                                        <span class="sim-control-value" id="inpSlabWidthVal">15 m</span>
                                    </div>
                                    <input type="range" id="inpSlabWidth" min="5" max="80" value="15" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Döşeme Kalınlığı</span>
                                        <span class="sim-control-value" id="inpSlabThkVal">0.25 m</span>
                                    </div>
                                    <input type="range" id="inpSlabThk" min="0.12" max="0.50" step="0.01" value="0.25" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Toplam Kolon Sayısı</label>
                                    <input type="number" id="inpColCount" value="18" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Kolon Boyutları (Genişlik/Derinlik)</span>
                                        <span class="sim-control-value" id="inpColDimVal">0.60 m</span>
                                    </div>
                                    <input type="range" id="inpColDim" min="0.30" max="1.20" step="0.05" value="0.60" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Kolon Yüksekliği (m)</label>
                                    <input type="number" id="inpColHeight" value="3.5" step="0.1" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Perde Duvar Sayısı</label>
                                    <input type="number" id="inpShearWallCount" value="4" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Tek Perde Duvar Uzunluğu (m)</label>
                                    <input type="number" id="inpShearWallLen" value="5.0" step="0.5" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Perde Duvar Kalınlığı (m)</label>
                                    <input type="number" id="inpShearWallThk" value="0.30" step="0.05" class="sim-select" style="padding:0.5rem;" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label">Demir/Donatı Birim Oranı (kg/m³ Beton)</label>
                                    <input type="number" id="inpRebarRatio" value="120" step="5" class="sim-select" style="padding:0.5rem;" />
                                </div>

                                <button type="button" class="btn btn-primary calc-btn" id="btnCalcBeton" style="width: 100%; margin-top: 0.5rem; justify-content: center; display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                                    ⚡ Beton &amp; Kalıp Metrajını Hesapla
                                </button>
                            </div>
                        </div>
                        <div class="metraj-table-panel sim-glass-card">
                            <h4 class="metraj-panel-title">Kaba İnşaat Malzeme Metraj Tablosu (Beton, Kalıp, Demir)</h4>
                            <table class="metraj-table">
                                <thead>
                                    <tr>
                                        <th>Poz No</th>
                                        <th>Açıklama (Structural Item)</th>
                                        <th>Metraj Miktarı</th>
                                        <th>Birim</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>B-01</td><td>Döşeme Beton Hacmi (C30/37)</td><td id="outSlabConcrete">-</td><td>m³</td></tr>
                                    <tr><td>B-02</td><td>Döşeme Altı Kalıp Yatay Alanı</td><td id="outSlabForm">-</td><td>m²</td></tr>
                                    <tr><td>B-03</td><td>Kolon Beton Hacmi</td><td id="outColConcrete">-</td><td>m³</td></tr>
                                    <tr><td>B-04</td><td>Kolon Çevre Düşey Kalıp Alanı</td><td id="outColForm">-</td><td>m²</td></tr>
                                    <tr><td>B-05</td><td>Perde Duvar Beton Hacmi</td><td id="outWallConcrete">-</td><td>m³</td></tr>
                                    <tr><td>B-06</td><td>Perde Duvar Kalıp Alanı (Çift Yüzlü Toplam)</td><td id="outWallForm">-</td><td>m²</td></tr>
                                    <tr><td>B-07</td><td>Toplam Kaba İnşaat Beton Hacmi</td><td id="outTotalConcrete">-</td><td>m³</td></tr>
                                    <tr><td>B-08</td><td>Toplam Beton Kütlesi/Ağırlığı</td><td id="outTotalConcreteWeight">-</td><td>Ton</td></tr>
                                    <tr><td>B-09</td><td>Toplam İnşaat Donatısı (Rebar) Ağırlığı</td><td id="outTotalRebarWeight">-</td><td>Ton</td></tr>
                                    <tr><td>B-10</td><td>Donatı Bağlama Demir Teli Miktarı</td><td id="outTieWire">-</td><td>kg</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- TAB 4: MASONRY & PLASTER ESTIMATOR (11 METRICS) -->
                <div class="sim-tab-panel" id="tab-duvar">
                    <div class="metraj-grid">
                        <div class="metraj-controls-panel sim-glass-card">
                            <h4 class="metraj-panel-title">Duvar &amp; Sıva Parametreleri</h4>
                            <div class="sim-controls-wrapper">
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Toplam Duvar Uzunluğu</span>
                                        <span class="sim-control-value" id="inpWallLenVal">40 m</span>
                                    </div>
                                    <input type="range" id="inpWallLen" min="5" max="250" value="40" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <div class="sim-control-label-row">
                                        <span class="sim-control-label">Kat Yüksekliği (Duvar Yüksekliği)</span>
                                        <span class="sim-control-value" id="inpWallHeightVal">3.20 m</span>
                                    </div>
                                    <input type="range" id="inpWallHeight" min="2.2" max="5.0" step="0.1" value="3.2" class="sim-range-input" />
                                </div>
                                <div class="sim-control-group">
                                    <label class="sim-control-label" for="inpWallType">Duvar Malzeme Türü</label>
                                    <select id="inpWallType" class="sim-select">
